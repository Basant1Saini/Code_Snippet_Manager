{
  "name": "code-snippet-manager",
  "version": "1.0.0",
  "description": "A web app to create, organize, search, and share reusable code snippets",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch server/index.js",
    "dev:client": "vite client",
    "build": "vite build client",
    "start": "node server/index.js",
    "db:migrate": "node migrations/migrate.js",
    "test": "node --test"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "vite": "^5.4.8"
  },
  "engines": {
    "node": ">=20.x"
  }
}
